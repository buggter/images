<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chaos Arena: AI Battle Royale</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { margin: 0; overflow: hidden; background: #000; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; user-select: none; }
        canvas { display: block; }
        
        #ui-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; display: none; }
        
        /* Main Menu Styling */
        #main-menu { position: absolute; inset: 0; background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); display: flex; flex-direction: column; align-items: center; justify-content: center; color: white; z-index: 4000; }
        .menu-card { background: rgba(0,0,0,0.4); backdrop-filter: blur(10px); padding: 2rem; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); width: 400px; }
        .btn-primary { background: #3b82f6; color: white; padding: 12px 24px; border-radius: 8px; font-weight: bold; transition: all 0.2s; width: 100%; text-align: center; cursor: pointer; margin-top: 10px; }
        .btn-primary:hover { background: #2563eb; transform: translateY(-2px); }
        
        /* HUD Elements */
        .hud-card { background: rgba(0,0,0,0.7); border: 2px solid #444; border-radius: 12px; padding: 15px; pointer-events: auto; }
        .skill-slot { width: 80px; height: 100px; display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(20,20,20,0.9); border: 2px solid #444; border-radius: 8px; transition: all 0.2s; position: relative; overflow: hidden; }
        .skill-slot.ready { border-color: #00ff00; box-shadow: 0 0 10px rgba(0,255,0,0.2); }
        .skill-slot.active { border-color: #3b82f6; background: rgba(59,130,246,0.3); }
        .cooldown-overlay { position: absolute; bottom: 0; left: 0; width: 100%; background: rgba(255,255,255,0.2); height: 0%; transition: height 0.1s linear; }
        
        .kill-feed { position: absolute; top: 20px; right: 20px; text-align: right; color: white; text-shadow: 1px 1px 2px black; font-weight: bold; pointer-events: none; }
        .crosshair { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 24px; height: 24px; border: 2px solid rgba(255,255,255,0.4); border-radius: 50%; pointer-events: none; }
        
        /* Effects */
        .lobotomy-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle, rgba(255,0,255,0.3) 0%, rgba(0,255,0,0.3) 100%); mix-blend-mode: hard-light; display: none; pointer-events: none; z-index: 1000; filter: blur(4px) hue-rotate(90deg); animation: flicker 0.1s infinite; }
        @keyframes flicker { 0% { opacity: 0.8; } 50% { opacity: 1; } 100% { opacity: 0.8; } }
        
        #death-screen { position: absolute; inset: 0; background: rgba(60,0,0,0.8); display: none; flex-direction: column; align-items: center; justify-content: center; color: white; font-size: 3rem; text-transform: uppercase; font-weight: 900; pointer-events: auto; z-index: 2000; }
        
        /* Label styling */
        .entity-label { position: absolute; color: white; background: rgba(0,0,0,0.5); padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; pointer-events: none; transform: translate(-50%, -100%); white-space: nowrap; border: 1px solid rgba(255,255,255,0.2); }
        
        /* Dialogue Bubble */
        .dialogue-bubble { 
            position: absolute; 
            background: white; 
            color: black; 
            padding: 4px 8px; 
            border-radius: 12px; 
            font-size: 18px; 
            pointer-events: none; 
            transform: translate(-50%, -240%); 
            white-space: nowrap; 
            border: 2px solid #333;
            animation: popIn 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .dialogue-bubble::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            border-width: 8px 6px 0 6px;
            border-style: solid;
            border-color: white transparent transparent transparent;
        }
        @keyframes popIn {
            0% { transform: translate(-50%, -240%) scale(0); opacity: 0; }
            100% { transform: translate(-50%, -240%) scale(1); opacity: 1; }
        }
    </style>
</head>
<body>

    <!-- Main Menu -->
    <div id="main-menu">
        <h1 class="text-6xl font-black mb-8 italic tracking-tighter text-blue-400">CHAOS ARENA</h1>
        
        <div class="menu-card space-y-6">
            <div id="view-home" class="space-y-4">
                <div onclick="startGame()" class="btn-primary text-xl py-4">ENTER BATTLE</div>
                <div onclick="switchMenu('skin')" class="btn-primary bg-gray-700">CUSTOMIZE SKIN</div>
                <div onclick="switchMenu('settings')" class="btn-primary bg-gray-700">SETTINGS</div>
            </div>

            <div id="view-skin" class="hidden space-y-4">
                <h2 class="text-xl font-bold border-b border-white/10 pb-2">Customize Skin</h2>
                <div class="grid grid-cols-4 gap-2">
                    <div onclick="setSkin('#00ff00')" class="w-full aspect-square bg-[#00ff00] cursor-pointer rounded-lg border-2 border-transparent hover:border-white"></div>
                    <div onclick="setSkin('#ff0000')" class="w-full aspect-square bg-[#ff0000] cursor-pointer rounded-lg border-2 border-transparent hover:border-white"></div>
                    <div onclick="setSkin('#0000ff')" class="w-full aspect-square bg-[#0000ff] cursor-pointer rounded-lg border-2 border-transparent hover:border-white"></div>
                    <div onclick="setSkin('#ffff00')" class="w-full aspect-square bg-[#ffff00] cursor-pointer rounded-lg border-2 border-transparent hover:border-white"></div>
                    <div onclick="setSkin('#ff00ff')" class="w-full aspect-square bg-[#ff00ff] cursor-pointer rounded-lg border-2 border-transparent hover:border-white"></div>
                    <div onclick="setSkin('#00ffff')" class="w-full aspect-square bg-[#00ffff] cursor-pointer rounded-lg border-2 border-transparent hover:border-white"></div>
                    <div onclick="setSkin('#ffffff')" class="w-full aspect-square bg-[#ffffff] cursor-pointer rounded-lg border-2 border-transparent hover:border-white"></div>
                    <div onclick="setSkin('#ff8800')" class="w-full aspect-square bg-[#ff8800] cursor-pointer rounded-lg border-2 border-transparent hover:border-white"></div>
                </div>
                <div onclick="switchMenu('home')" class="btn-primary bg-gray-600">BACK</div>
            </div>

            <div id="view-settings" class="hidden space-y-4">
                <h2 class="text-xl font-bold border-b border-white/10 pb-2">Game Settings</h2>
                <div class="space-y-2">
                    <label class="text-xs uppercase opacity-60">AI Count</label>
                    <input type="range" id="ai-count-slider" min="1" max="20" value="10" class="w-full">
                    <div class="flex justify-between text-[10px]"><span>1 Bot</span><span id="ai-val">10 Bots</span><span>20 Bots</span></div>
                </div>
                <div class="flex items-center justify-between">
                    <span class="text-sm">Mute Audio</span>
                    <input type="checkbox" id="mute-check">
                </div>
                <div onclick="switchMenu('home')" class="btn-primary bg-gray-600">BACK</div>
            </div>
        </div>
    </div>

    <div id="ui-layer">
        <div class="crosshair"></div>
        <div id="lobotomy-effect" class="lobotomy-overlay"></div>
        <div id="labels-container" class="absolute inset-0 pointer-events-none"></div>
        
        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex space-x-4">
            <div id="skill-1" class="skill-slot">
                <span class="text-xs text-gray-400">1</span>
                <span class="skill-name text-[10px] font-bold text-white text-center px-1 uppercase">---</span>
                <div class="cooldown-overlay"></div>
            </div>
            <div id="skill-2" class="skill-slot">
                <span class="text-xs text-gray-400">2</span>
                <span class="skill-name text-[10px] font-bold text-white text-center px-1 uppercase">---</span>
                <div class="cooldown-overlay"></div>
            </div>
            <div id="skill-3" class="skill-slot">
                <span class="text-xs text-gray-400">3</span>
                <span class="skill-name text-[10px] font-bold text-white text-center px-1 uppercase">---</span>
                <div class="cooldown-overlay"></div>
            </div>
            <div class="flex flex-col items-center justify-center ml-4">
                <div id="dash-ui" class="w-10 h-10 border-2 border-white/20 rounded-full flex items-center justify-center text-[10px] text-white/50 font-bold">Q</div>
                <span class="text-[8px] text-white/40 uppercase mt-1">Dash</span>
            </div>
        </div>

        <div class="absolute top-5 left-5 hud-card text-white">
            <div class="text-lg font-black uppercase tracking-tighter">Arena Field</div>
            <div id="stats" class="text-xs opacity-70">Health: 100% | Target: None</div>
            <div class="text-[9px] opacity-40 mt-1 uppercase font-bold tracking-widest">[H] Manual Respawn</div>
        </div>

        <div id="kill-feed" class="kill-feed text-sm"></div>
    </div>

    <div id="death-screen">
        <div id="death-msg">Wasted</div>
        <div class="text-xl mt-4">Respawning in <span id="respawn-timer">3</span>...</div>
    </div>

    <script>
        /** CONSTANTS & SKILL DEFS **/
        const SKILL_TYPES = {
            TRAINS: { name: "Trains", cd: 50, color: '#ff4d4d' },
            HYDRAULIC: { name: "Hydraulic Press", cd: 50, color: '#cccccc' },
            SLIPPERY: { name: "Slippery", cd: 32, duration: 25, color: '#33ccff' },
            LOBOTOMY: { name: "Lobotomy", cd: 42, duration: 15, color: '#ff33ff' },
            LAUGHTER: { name: "Laughter of Death", cd: 50, delay: 10.54, color: '#cc0000' },
            DOG_ATTACK: { name: "Dog Attack", cd: 50, color: '#8b4513' },
            ADRENALINE: { name: "Adrenaline", cd: 41, duration: 8, color: '#ff0000' },
            SWITCH: { name: "Switch", cd: 12, color: '#00ffaa' },
            BOTH_WALLS: { name: "Both Walls", cd: 48, color: '#555555' }
        };

        const SKILL_LIST = Object.keys(SKILL_TYPES);
        const NICKNAMES = ["GamerGod", "NoobSlayer", "ChaosBringer", "Bot_404", "TheJanitor", "Skibidi", "RageQuitter", "L-Ratio", "DefaultSkin", "Speedy", "FragKing", "Glitched", "VibeCheck", "ZazaEnjoyer", "TheProblem"];
        const LAUGH_SOUND_URL = "https://github.com/buggter/images/raw/refs/heads/main/Evil%20Laugh%20Sound%20Effect%20(Your%20search%20is%20over).mp3";
        const DOG_BARK_URL = "https://github.com/buggter/images/raw/refs/heads/main/160092__jorickhoofd__dog-bark-1.mp3";
        const REACTION_EMOJIS = ["😡", "😤", "😒", "😵", "😖"];

        /** GAME ENGINE CORE **/
        let scene, camera, renderer, clock;
        let player, entities = [];
        let keys = {};
        const FIELD_SIZE = 120;
        let gameStarted = false;
        
        let config = {
            skinColor: '#00ff00',
            aiCount: 10,
            muted: false
        };

        // UI Management
        function switchMenu(view) {
            document.getElementById('view-home').classList.toggle('hidden', view !== 'home');
            document.getElementById('view-skin').classList.toggle('hidden', view !== 'skin');
            document.getElementById('view-settings').classList.toggle('hidden', view !== 'settings');
        }

        function setSkin(color) {
            config.skinColor = color;
            if (player) player.mesh.material.color.set(color);
        }

        document.getElementById('ai-count-slider').oninput = function() {
            config.aiCount = parseInt(this.value);
            document.getElementById('ai-val').textContent = config.aiCount + " Bots";
        };

        document.getElementById('mute-check').onchange = function() {
            config.muted = this.checked;
        };

        // Sound Engine
        let audioCtx;
        function initAudio() {
            if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }

        function playSound(url, vol = 0.6) {
            if (config.muted) return;
            const audio = new Audio(url);
            audio.volume = vol;
            audio.play().catch(e => console.log("Audio play blocked"));
        }

        function playTone(freq, duration, type = 'sine') {
            if (!audioCtx || config.muted) return;
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.type = type;
            osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            gain.gain.setValueAtTime(0.05, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + duration);
            osc.start();
            osc.stop(audioCtx.currentTime + duration);
        }

        class Entity {
            constructor(isPlayer = false, nickname = "AI") {
                this.isPlayer = isPlayer;
                this.nickname = nickname;
                this.dead = false;
                this.health = 100;
                this.skills = [];
                this.velocity = new THREE.Vector3();
                this.isSlippery = false;
                this.isFrozen = false;
                this.isLobotomized = false;
                this.isAdrenaline = false;
                
                // Dash state
                this.dashCD = 0;
                this.dashDuration = 0;

                // 3D Visual
                const geometry = new THREE.CylinderGeometry(0.5, 0.5, 1.6, 12);
                const material = new THREE.MeshStandardMaterial({ color: isPlayer ? config.skinColor : 0x4444ff });
                this.mesh = new THREE.Mesh(geometry, material);
                this.mesh.position.y = 1;
                scene.add(this.mesh);

                // Aura for skills
                this.aura = new THREE.Mesh(
                    new THREE.SphereGeometry(0.8, 8, 8),
                    new THREE.MeshBasicMaterial({ color: 0xff0000, transparent: true, opacity: 0, wireframe: true })
                );
                this.mesh.add(this.aura);

                // UI Label
                this.label = document.createElement('div');
                this.label.className = 'entity-label';
                this.label.textContent = this.nickname;
                if (this.isPlayer) this.label.style.color = '#ffff00';
                document.getElementById('labels-container').appendChild(this.label);

                // Bubble Ref
                this.activeBubble = null;

                this.spawn();
            }

            getRandomSkills() {
                const shuffled = [...SKILL_LIST].sort(() => 0.5 - Math.random());
                return shuffled.slice(0, 3).map(key => ({
                    ...SKILL_TYPES[key],
                    type: key,
                    currentCD: 0,
                    activeUntil: 0
                }));
            }

            spawn() {
                this.dead = false;
                this.health = 100;
                this.isSlippery = false;
                this.isFrozen = false;
                this.isLobotomized = false;
                this.isAdrenaline = false;
                this.dashCD = 0;
                this.aura.material.opacity = 0;
                this.velocity.set(0, 0, 0);
                
                this.skills = this.getRandomSkills();
                
                this.mesh.visible = true;
                this.label.style.display = 'block';
                this.mesh.position.set((Math.random() - 0.5) * (FIELD_SIZE - 20), 1, (Math.random() - 0.5) * (FIELD_SIZE - 20));
                
                if (this.isPlayer) {
                    document.getElementById('lobotomy-effect').style.display = 'none';
                    document.getElementById('death-screen').style.display = 'none';
                }
            }

            takeDamage(amt, killerId) {
                if (this.dead) return;
                this.health -= amt;
                
                if (!this.isPlayer) {
                    this.showDialogue();
                }

                playTone(150, 0.1, 'square');
                if (this.health <= 0) {
                    this.die(killerId);
                }
            }

            showDialogue() {
                if (this.activeBubble) return; // Don't stack
                
                const emoji = REACTION_EMOJIS[Math.floor(Math.random() * REACTION_EMOJIS.length)];
                const bubble = document.createElement('div');
                bubble.className = 'dialogue-bubble';
                bubble.textContent = emoji;
                document.getElementById('labels-container').appendChild(bubble);
                this.activeBubble = bubble;

                setTimeout(() => {
                    if (this.activeBubble === bubble) {
                        bubble.remove();
                        this.activeBubble = null;
                    }
                }, 1500);
            }

            die(killerId) {
                if (this.dead) return;
                this.dead = true;
                this.mesh.visible = false;
                this.label.style.display = 'none';
                if (this.activeBubble) {
                    this.activeBubble.remove();
                    this.activeBubble = null;
                }
                
                const feed = document.getElementById('kill-feed');
                const entry = document.createElement('div');
                entry.style.color = killerId === "Player" ? "#00ff00" : (killerId === "Reset" ? "#aaa" : "#ff4444");
                
                if (killerId === "Reset") {
                    entry.textContent = `♻️ ${this.nickname} respawned`;
                } else {
                    entry.textContent = `${killerId} ➔ ${this.nickname}`;
                }
                
                feed.prepend(entry);
                setTimeout(() => entry.remove(), 4000);

                if (this.isPlayer) {
                    const deathMsg = document.getElementById('death-msg');
                    deathMsg.textContent = killerId === "Reset" ? "Respawning" : "Wasted";
                    document.getElementById('death-screen').style.display = 'flex';
                    
                    let timeLeft = 3;
                    const timerEl = document.getElementById('respawn-timer');
                    timerEl.textContent = timeLeft;
                    const interval = setInterval(() => {
                        timeLeft--;
                        timerEl.textContent = timeLeft;
                        if (timeLeft <= 0) {
                            clearInterval(interval);
                            this.spawn();
                        }
                    }, 1000);
                } else {
                    setTimeout(() => { if(this.dead) this.spawn(); }, 3000);
                }
            }

            update(dt) {
                if (this.dead) return;

                if (this.dashCD > 0) this.dashCD -= dt;
                if (this.dashDuration > 0) {
                    this.dashDuration -= dt;
                    this.createTrail();
                }

                this.skills.forEach(s => {
                    if (s.currentCD > 0) s.currentCD -= dt;
                    if (s.activeUntil > 0 && Date.now() > s.activeUntil) {
                        if (s.type === 'SLIPPERY') this.isSlippery = false;
                        if (s.type === 'ADRENALINE') {
                            this.isAdrenaline = false;
                            this.aura.material.opacity = 0;
                        }
                        s.activeUntil = 0;
                    }
                });

                if (this.isPlayer) {
                    this.handlePlayerMovement(dt);
                    if (keys['q'] && this.dashCD <= 0) this.performDash();
                    if (keys['h']) this.die("Reset");
                } else {
                    this.handleAIMovement(dt);
                    this.handleAISkills();
                }

                // Handle Adrenaline collision logic
                if (this.isAdrenaline) {
                    entities.forEach(other => {
                        if (other !== this && !other.dead && this.mesh.position.distanceTo(other.mesh.position) < 2) {
                            const pushDir = other.mesh.position.clone().sub(this.mesh.position).normalize();
                            other.mesh.position.add(pushDir.multiplyScalar(0.5));
                            other.takeDamage(10, this.nickname);
                        }
                    });
                }

                // Keep in bounds
                const limit = FIELD_SIZE / 2;
                this.mesh.position.x = Math.max(-limit, Math.min(limit, this.mesh.position.x));
                this.mesh.position.z = Math.max(-limit, Math.min(limit, this.mesh.position.z));

                // Update UI Element Positions (Labels & Bubbles)
                const pos = this.mesh.position.clone();
                pos.y += 1.8;
                pos.project(camera);
                const x = (pos.x * 0.5 + 0.5) * window.innerWidth;
                const y = (pos.y * -0.5 + 0.5) * window.innerHeight;
                
                const visible = (pos.z < 1 && gameStarted);
                this.label.style.left = `${x}px`;
                this.label.style.top = `${y}px`;
                this.label.style.opacity = visible ? 1 : 0;
                
                if (this.activeBubble) {
                    this.activeBubble.style.left = `${x}px`;
                    this.activeBubble.style.top = `${y}px`;
                    this.activeBubble.style.opacity = visible ? 1 : 0;
                }
            }

            performDash() {
                const moveDir = new THREE.Vector3();
                if (keys['w']) moveDir.z -= 1;
                if (keys['s']) moveDir.z += 1;
                if (keys['a']) moveDir.x -= 1;
                if (keys['d']) moveDir.x += 1;
                
                if (moveDir.length() === 0) return; 
                
                moveDir.normalize();
                this.velocity.add(moveDir.multiplyScalar(1.2));
                this.dashCD = 1.5;
                this.dashDuration = 0.25;
                playTone(400, 0.1, 'sine');
            }

            createTrail() {
                const ghost = new THREE.Mesh(this.mesh.geometry, new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.3 }));
                ghost.position.copy(this.mesh.position);
                scene.add(ghost);
                const start = Date.now();
                const fade = () => {
                    ghost.material.opacity -= 0.02;
                    if (ghost.material.opacity > 0) requestAnimationFrame(fade);
                    else scene.remove(ghost);
                };
                fade();
            }

            handlePlayerMovement(dt) {
                if (this.isFrozen) return;

                let speed = 10.5;
                if (this.isSlippery) speed = 25;
                if (this.isAdrenaline) speed = 20;

                const friction = this.isSlippery ? 0.985 : 0.82;

                const dir = new THREE.Vector3();
                if (keys['w']) dir.z -= 1;
                if (keys['s']) dir.z += 1;
                if (keys['a']) dir.x -= 1;
                if (keys['d']) dir.x += 1;
                
                if (dir.length() > 0) {
                    dir.normalize().multiplyScalar(speed * dt);
                    this.velocity.add(dir);
                }

                this.mesh.position.add(this.velocity);
                this.velocity.multiplyScalar(friction);
                
                camera.position.set(this.mesh.position.x, this.mesh.position.y + 12, this.mesh.position.z + 20);
                camera.lookAt(this.mesh.position.x, this.mesh.position.y, this.mesh.position.z);
            }

            handleAIMovement(dt) {
                if (this.isFrozen) return;
                
                if (!this.targetPos || Math.random() < 0.01 || this.mesh.position.distanceTo(this.targetPos) < 2) {
                    this.targetPos = new THREE.Vector3((Math.random() - 0.5) * FIELD_SIZE, 1, (Math.random() - 0.5) * FIELD_SIZE);
                }
                
                const speed = (this.isSlippery || this.isAdrenaline) ? 0.35 : 0.12;
                const dir = this.targetPos.clone().sub(this.mesh.position).normalize();
                this.mesh.position.add(dir.multiplyScalar(speed));
            }

            handleAISkills() {
                this.skills.forEach((s, idx) => {
                    if (s.currentCD <= 0 && Math.random() < 0.003) {
                        const targets = entities.filter(e => e !== this && !e.dead);
                        if (targets.length > 0) {
                            const target = targets[Math.floor(Math.random() * targets.length)];
                            this.useSkill(idx, target);
                        }
                    }
                });
            }

            useSkill(slotIdx, target) {
                const skill = this.skills[slotIdx];
                if (!skill || skill.currentCD > 0 || this.dead || this.isFrozen) return;

                switch(skill.type) {
                    case 'TRAINS':
                        if (!target) return;
                        skill.currentCD = skill.cd;
                        this.visualTrain(target);
                        break;
                    case 'HYDRAULIC':
                        if (!target) return;
                        skill.currentCD = skill.cd;
                        this.visualPress(target);
                        break;
                    case 'SLIPPERY':
                        skill.currentCD = skill.cd;
                        skill.activeUntil = Date.now() + (skill.duration * 1000);
                        this.isSlippery = true;
                        playTone(300, 0.4, 'sine');
                        break;
                    case 'LOBOTOMY':
                        if (!target) return;
                        skill.currentCD = skill.cd;
                        this.applyLobotomy(target);
                        break;
                    case 'LAUGHTER':
                        if (!target) return;
                        skill.currentCD = skill.cd;
                        this.applyLaughter(target);
                        break;
                    case 'DOG_ATTACK':
                        if (!target) return;
                        skill.currentCD = skill.cd;
                        this.visualDog(target);
                        break;
                    case 'ADRENALINE':
                        skill.currentCD = skill.cd;
                        skill.activeUntil = Date.now() + (skill.duration * 1000);
                        this.isAdrenaline = true;
                        this.aura.material.opacity = 0.5;
                        playTone(200, 0.5, 'square');
                        break;
                    case 'SWITCH':
                        if (!target) return;
                        skill.currentCD = skill.cd;
                        this.performSwitch(target);
                        break;
                    case 'BOTH_WALLS':
                        if (!target) return;
                        skill.currentCD = skill.cd;
                        this.visualWalls(target);
                        break;
                }
            }

            visualTrain(target) {
                playTone(80, 2, 'sawtooth');
                const train = new THREE.Mesh(new THREE.BoxGeometry(8, 3, 5), new THREE.MeshStandardMaterial({color: 0x111111}));
                train.position.set(target.mesh.position.x - 40, 1.5, target.mesh.position.z);
                scene.add(train);
                const start = Date.now();
                const animateTrain = () => {
                    if (train.parent === null) return;
                    train.position.x += 1.5;
                    if (train.position.x > target.mesh.position.x - 3 && train.position.x < target.mesh.position.x + 3) {
                        target.die(this.nickname);
                    }
                    if (Date.now() - start < 1500) requestAnimationFrame(animateTrain);
                    else scene.remove(train);
                };
                animateTrain();
            }

            visualDog(target) {
                target.isFrozen = true;
                const dog = new THREE.Group();
                const body = new THREE.Mesh(new THREE.BoxGeometry(1.2, 0.8, 0.6), new THREE.MeshStandardMaterial({color: 0x5d4037}));
                const head = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.6, 0.6), new THREE.MeshStandardMaterial({color: 0x5d4037}));
                head.position.set(0.6, 0.4, 0);
                dog.add(body, head);
                dog.position.set(target.mesh.position.x - 5, 0.5, target.mesh.position.z);
                scene.add(dog);

                let hits = 0;
                const strike = () => {
                    const startPos = dog.position.clone();
                    const targetPos = target.mesh.position.clone();
                    let alpha = 0;
                    playSound(DOG_BARK_URL);
                    const lunge = () => {
                        alpha += 0.1;
                        if (alpha <= 1) {
                            dog.position.lerpVectors(startPos, targetPos, Math.sin(alpha * Math.PI));
                            requestAnimationFrame(lunge);
                        } else {
                            hits++;
                            playTone(600, 0.1, 'square');
                            if (hits < 3) {
                                setTimeout(strike, 600);
                            } else {
                                target.die(this.nickname);
                                scene.remove(dog);
                            }
                        }
                    };
                    lunge();
                };
                strike();
            }

            performSwitch(target) {
                playTone(800, 0.2, 'sine');
                const p1 = this.mesh.position.clone();
                const p2 = target.mesh.position.clone();
                this.mesh.position.copy(p2);
                target.mesh.position.copy(p1);
                
                const sparkle = new THREE.Mesh(new THREE.SphereGeometry(1.5, 8, 8), new THREE.MeshBasicMaterial({ color: 0x00ffaa, wireframe: true }));
                sparkle.position.copy(p1);
                scene.add(sparkle);
                const sparkle2 = sparkle.clone();
                sparkle2.position.copy(p2);
                scene.add(sparkle2);
                setTimeout(() => { scene.remove(sparkle); scene.remove(sparkle2); }, 300);
            }

            visualWalls(target) {
                target.isFrozen = true;
                const wall1 = new THREE.Mesh(new THREE.BoxGeometry(1, 6, 6), new THREE.MeshStandardMaterial({color: 0x444444}));
                const wall2 = new THREE.Mesh(new THREE.BoxGeometry(1, 6, 6), new THREE.MeshStandardMaterial({color: 0x444444}));
                wall1.position.set(target.mesh.position.x - 6, 3, target.mesh.position.z);
                wall2.position.set(target.mesh.position.x + 6, 3, target.mesh.position.z);
                scene.add(wall1, wall2);

                const crush = () => {
                    wall1.position.x += 0.05;
                    wall2.position.x -= 0.05;
                    if (wall1.position.x >= target.mesh.position.x - 0.5) {
                        playTone(50, 0.5, 'square');
                        target.die(this.nickname);
                        setTimeout(() => { scene.remove(wall1); scene.remove(wall2); }, 1000);
                    } else {
                        requestAnimationFrame(crush);
                    }
                };
                crush();
            }

            visualPress(target) {
                target.isFrozen = true;
                const press = new THREE.Mesh(new THREE.BoxGeometry(5, 2, 5), new THREE.MeshStandardMaterial({color: 0x777777}));
                press.position.set(target.mesh.position.x, 25, target.mesh.position.z);
                scene.add(press);
                setTimeout(() => {
                    playTone(40, 0.4, 'square');
                    const drop = () => {
                        if (press.parent === null) return;
                        press.position.y -= 1.0;
                        if (press.position.y <= 1.5) {
                            target.die(this.nickname);
                            setTimeout(() => scene.remove(press), 800);
                        } else {
                            requestAnimationFrame(drop);
                        }
                    };
                    drop();
                }, 1200);
            }

            applyLobotomy(target) {
                playTone(1000, 0.1, 'sine');
                if (target.isPlayer) {
                    const el = document.getElementById('lobotomy-effect');
                    el.style.display = 'block';
                    setTimeout(() => el.style.display = 'none', 15000);
                }
                const glow = new THREE.Mesh(new THREE.TorusGeometry(1.0, 0.1, 4, 12), new THREE.MeshBasicMaterial({color: 0xff00ff}));
                glow.position.y = 1.2;
                target.mesh.add(glow);
                setTimeout(() => target.mesh.remove(glow), 15000);
            }

            applyLaughter(target) {
                target.isFrozen = true;
                if (target.isPlayer || this.isPlayer) playSound(LAUGH_SOUND_URL);
                const laughMarker = new THREE.Mesh(new THREE.TorusGeometry(0.8, 0.05, 8, 16), new THREE.MeshBasicMaterial({color: 0xff0000}));
                laughMarker.rotation.x = Math.PI/2;
                laughMarker.position.y = 1.8;
                target.mesh.add(laughMarker);
                setTimeout(() => {
                    target.mesh.remove(laughMarker);
                    target.die(this.nickname);
                }, 10540);
            }
        }

        /** INITIALIZATION **/
        function startGame() {
            document.getElementById('main-menu').style.display = 'none';
            document.getElementById('ui-layer').style.display = 'block';
            initAudio();
            
            entities.forEach(e => {
                scene.remove(e.mesh);
                e.label.remove();
                if (e.activeBubble) e.activeBubble.remove();
            });
            entities = [];

            player = new Entity(true, "Player");
            player.mesh.material.color.set(config.skinColor);
            entities.push(player);

            for(let i=0; i<config.aiCount; i++) {
                const nick = NICKNAMES[Math.floor(Math.random()*NICKNAMES.length)] + "_" + (i+1);
                entities.push(new Entity(false, nick));
            }

            gameStarted = true;
        }

        function init() {
            scene = new THREE.Scene();
            
            const skyGeo = new THREE.SphereGeometry(800, 32, 32);
            const skyMat = new THREE.MeshBasicMaterial({ side: THREE.BackSide, vertexColors: true });
            const count = skyGeo.attributes.position.count;
            skyGeo.setAttribute('color', new THREE.BufferAttribute(new Float32Array(count * 3), 3));
            const colors = skyGeo.attributes.color;
            for (let i = 0; i < count; i++) {
                const y = skyGeo.attributes.position.getY(i);
                if (y > 0) colors.setXYZ(i, 0.4, 0.9, 1.0);
                else colors.setXYZ(i, 1.0, 0.6, 0.8);
            }
            scene.add(new THREE.Mesh(skyGeo, skyMat));

            camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 0.1, 4000);
            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            document.body.appendChild(renderer.domElement);

            scene.add(new THREE.AmbientLight(0xffffff, 0.8));
            const sun = new THREE.DirectionalLight(0xffffff, 1.0);
            sun.position.set(30, 80, 40);
            scene.add(sun);

            const floor = new THREE.Mesh(
                new THREE.PlaneGeometry(FIELD_SIZE, FIELD_SIZE), 
                new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.2 })
            );
            floor.rotation.x = -Math.PI/2;
            scene.add(floor);
            scene.add(new THREE.GridHelper(FIELD_SIZE, 24, 0x555555, 0x333333));

            clock = new THREE.Clock();
            animate();
        }

        function animate() {
            requestAnimationFrame(animate);
            const dt = clock.getDelta();

            if (!gameStarted) {
                if(camera) {
                    camera.position.x = Math.sin(Date.now() * 0.0002) * 60;
                    camera.position.z = Math.cos(Date.now() * 0.0002) * 60;
                    camera.position.y = 35;
                    camera.lookAt(0,0,0);
                    renderer.render(scene, camera);
                }
                return;
            }

            entities.forEach(e => e.update(dt));
            
            if (player && !player.dead) {
                const target = getNearestTarget();
                if (keys['1']) player.useSkill(0, target);
                if (keys['2']) player.useSkill(1, target);
                if (keys['3']) player.useSkill(2, target);
                updateUI(target);
            }

            renderer.render(scene, camera);
        }

        function getNearestTarget() {
            let nearest = null;
            let minDist = 80;
            entities.forEach(e => {
                if (e === player || e.dead) return;
                const d = e.mesh.position.distanceTo(player.mesh.position);
                if (d < minDist) {
                    minDist = d;
                    nearest = e;
                }
            });
            return nearest;
        }

        function updateUI(target) {
            document.getElementById('stats').innerHTML = `
                STATUS: ${player.dead ? 'DEAD' : 'ALIVE'} | 
                TARGET: <span style="color:${target ? '#0f0' : '#f44'}">${target ? target.nickname : 'NONE'}</span>
            `;

            player.skills.forEach((s, i) => {
                const slot = document.getElementById(`skill-${i+1}`);
                const name = slot.querySelector('.skill-name');
                const overlay = slot.querySelector('.cooldown-overlay');
                if (name) name.textContent = s.name;
                if (overlay) overlay.style.height = `${(Math.max(0, s.currentCD) / s.cd) * 100}%`;
                slot.className = `skill-slot ${s.currentCD <= 0 ? 'ready' : ''} ${s.activeUntil > Date.now() ? 'active' : ''}`;
            });

            const dashUI = document.getElementById('dash-ui');
            const dashPerc = (Math.max(0, player.dashCD) / 1.5) * 100;
            dashUI.style.borderColor = player.dashCD <= 0 ? '#0f0' : 'rgba(255,255,255,0.2)';
            dashUI.style.background = `linear-gradient(to top, rgba(0,255,0,0.2) ${100-dashPerc}%, transparent 0%)`;
        }

        window.addEventListener('keydown', e => keys[e.key.toLowerCase()] = true);
        window.addEventListener('keyup', e => keys[e.key.toLowerCase()] = false);
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        window.onload = init;
    </script>
</body>
</html>
